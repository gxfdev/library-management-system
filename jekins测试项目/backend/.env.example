# ===========================================
# 生产环境配置示例
# 复制为 .env 并修改实际值
# ===========================================

# MySQL 数据库配置
MYSQL_ROOT_PASSWORD=your_secure_password_here
MYSQL_DB=library_db
MYSQL_PORT=3306

# JWT 密钥 (至少 32 字符)
JWT_SECRET=changeThisToASecureRandomStringInProduction2024

# AES 加密密钥 (必须 32 字节)
AES_SECRET_KEY=changeThisToA32ByteSecureKeyInProd1234567890

# CORS 允许的源 (逗号分隔)
CORS_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com

# 端口配置
BACKEND_PORT=8080
FRONTEND_PORT=80
